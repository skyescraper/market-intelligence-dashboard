import { NextResponse } from "next/server";
import Parser from "rss-parser";

export const runtime = "nodejs";
export const dynamic = "force-dynamic";

const parser = new Parser();

interface KOLUpdate {
  title: string;
  titleEn: string;
  description: string;
  source: string;
  company: string;
  isKOL: boolean;
  kolName?: string;
  url: string;
  publishedAt: Date;
  category: string;
  importance: 1 | 2 | 3;
  tags: string[];
  platform: "X" | "Blog" | "LinkedIn" | "Official";
}

